/* app.wxss - 全局样式 */

page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #333;
}

/* 容器 */
.container {
  padding: 20rpx;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 20rpx;
}

/* 指标网格 */
.metrics-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -10rpx;
}

.metric-item {
  width: 50%;
  padding: 10rpx;
  box-sizing: border-box;
}

.metric-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  padding: 24rpx;
  color: #fff;
}

.metric-card.green {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
}

.metric-card.red {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
}

.metric-card.blue {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
}

.metric-card.purple {
  background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
}

.metric-label {
  font-size: 24rpx;
  opacity: 0.9;
  margin-bottom: 8rpx;
}

.metric-value {
  font-size: 40rpx;
  font-weight: 700;
}

/* 列表 */
.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eee;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-left {
  flex: 1;
}

.list-item-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1a1a2e;
  margin-bottom: 8rpx;
}

.list-item-subtitle {
  font-size: 24rpx;
  color: #666;
}

.list-item-right {
  text-align: right;
}

.list-item-value {
  font-size: 32rpx;
  font-weight: 600;
}

.list-item-value.positive {
  color: #10b981;
}

.list-item-value.negative {
  color: #ef4444;
}

/* 按钮 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-primary {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #fff;
}

.btn-secondary {
  background: #f3f4f6;
  color: #374151;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
}

.tag-success {
  background: #d1fae5;
  color: #059669;
}

.tag-warning {
  background: #fef3c7;
  color: #d97706;
}

.tag-danger {
  background: #fee2e2;
  color: #dc2626;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  color: #999;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

/* 图表容器 */
.chart-container {
  width: 100%;
  height: 400rpx;
}
