.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
  border-radius: 20rpx;
  color: white;
  margin-bottom: 30rpx;
}

.strategy-name {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.backtest-id {
  font-size: 24rpx;
  opacity: 0.8;
}

.time {
  font-size: 24rpx;
  opacity: 0.7;
  margin-top: 10rpx;
}

.metrics-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.metric-card {
  background: white;
  padding: 30rpx;
  border-radius: 16rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.metric-value {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
}

.metric-card.positive .metric-value {
  color: #10b981;
}

.metric-card.negative .metric-value {
  color: #ef4444;
}

.metric-label {
  font-size: 24rpx;
  color: #666;
  margin-top: 10rpx;
}

.chart-section {
  background: white;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #667eea;
}

.chart-canvas {
  width: 100%;
  height: 400rpx;
}

.detail-section {
  background: white;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.detail-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-item .label {
  color: #666;
  font-size: 26rpx;
}

.detail-item .value {
  color: #333;
  font-weight: 500;
  font-size: 26rpx;
}

.detail-item .value.positive {
  color: #10b981;
}

.detail-item .value.negative {
  color: #ef4444;
}

.trades-section {
  background: white;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.trades-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.trade-item {
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.trade-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.trade-date {
  font-size: 26rpx;
  color: #666;
}

.trade-pnl {
  font-size: 28rpx;
  font-weight: bold;
}

.trade-pnl.positive {
  color: #10b981;
}

.trade-pnl.negative {
  color: #ef4444;
}

.trade-detail {
  font-size: 24rpx;
  color: #999;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
}

.btn-export, .btn-share {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-export {
  background: #667eea;
  color: white;
}

.btn-share {
  background: white;
  color: #667eea;
  border: 2rpx solid #667eea;
}
