<!-- pages/strategies/strategies.wxml -->
<view class="container">
  <view class="page-header">
    <view class="page-title">策略库</view>
    <view class="page-subtitle">选择策略运行回测</view>
  </view>

  <!-- 策略列表 -->
  <view class="strategy-list">
    <view class="strategy-card" wx:for="{{strategies}}" wx:key="id" bindtap="selectStrategy" data-id="{{item.id}}">
      <view class="strategy-header">
        <view class="strategy-name">{{item.name}}</view>
        <view class="strategy-status {{item.is_active ? 'active' : 'inactive'}}">
          {{item.is_active ? '启用' : '停用'}}
        </view>
      </view>
      
      <view class="strategy-desc">{{item.description}}</view>
      
      <view class="strategy-meta">
        <view class="meta-item">
          <text class="meta-label">品种</text>
          <text class="meta-value">{{item.symbol}}</text>
        </view>
        <view class="meta-item">
          <text class="meta-label">类型</text>
          <text class="meta-value">{{item.strategy_type}}</text>
        </view>
      </view>

      <view class="strategy-params" wx:if="{{item.parameters}}">
        <view class="params-title">参数配置</view>
        <view class="params-grid">
          <view class="param-item" wx:for="{{item.paramsList}}" wx:for-item="param" wx:key="key">
            <text class="param-key">{{param.key}}</text>
            <text class="param-value">{{param.value}}</text>
          </view>
        </view>
      </view>

      <view class="strategy-actions">
        <button class="btn btn-primary btn-sm" catchtap="runBacktest" data-id="{{item.id}}">
          运行回测
        </button>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{strategies.length === 0 && !loading}}">
    <view class="empty-icon">📊</view>
    <view class="empty-text">暂无策略配置</view>
  </view>
</view>

<!-- 回测配置弹窗 -->
<view class="modal" wx:if="{{showModal}}">
  <view class="modal-mask" bindtap="closeModal"></view>
  <view class="modal-content">
    <view class="modal-header">
      <view class="modal-title">回测配置</view>
      <view class="modal-close" bindtap="closeModal">×</view>
    </view>
    <view class="modal-body">
      <view class="form-item">
        <view class="form-label">回测天数</view>
        <picker mode="selector" range="{{dayOptions}}" value="{{dayIndex}}" bindchange="onDayChange">
          <view class="form-picker">{{dayOptions[dayIndex]}}天</view>
        </picker>
      </view>
      <view class="form-item">
        <view class="form-label">初始资金</view>
        <input class="form-input" type="digit" value="{{initialCapital}}" bindinput="onCapitalChange" placeholder="100万"/>
      </view>
    </view>
    <view class="modal-footer">
      <button class="btn btn-secondary" bindtap="closeModal">取消</button>
      <button class="btn btn-primary" bindtap="confirmBacktest" loading="{{running}}">
        {{running ? '运行中...' : '开始回测'}}
      </button>
    </view>
  </view>
</view>
