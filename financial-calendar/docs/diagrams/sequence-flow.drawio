        <mxCell id="msg3b" value="3. Validate spread within&#xa;min/max bounds" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=classic;strokeColor=#34C759;fontSize=9;fontColor=#34C759;dashed=1;labelBackgroundColor=none;" edge="1" parent="1">
