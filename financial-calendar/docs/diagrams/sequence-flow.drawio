        <mxCell id="msg2" value="1. Send WIDENING_START signal&#xa;(event_id, impact, affected_pairs)" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=classic;strokeColor=#FF9500;strokeWidth=2;fontSize=9;fontColor=#FF9500;labelBackgroundColor=none;" edge="1" parent="1">
