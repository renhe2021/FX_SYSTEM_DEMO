        <!-- Step 4 -->
        <mxCell id="s4" value="&lt;b&gt;OUTPUT&lt;/b&gt;&lt;br&gt;定制化研报&lt;br&gt;&lt;font style=&quot;font-size:10px;color:rgba(255,255,255,0.85)&quot;&gt;投行级 · PDF/HTML · 中英双语&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=40;fillColor=#0052D9;strokeColor=#0052D9;fontColor=#FFFFFF;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="770" y="90" width="200" height="110" as="geometry"/>
