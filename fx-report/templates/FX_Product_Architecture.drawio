        <mxCell id="s1" value="&lt;b&gt;STEP 1&lt;/b&gt;&lt;br&gt;选择客户&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;画像 · 走廊 · Tier 分级&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=40;fillColor=#E8F5E9;strokeColor=#66BB6A;fontColor=#2E7D32;fontSize=14;" vertex="1" parent="1">
