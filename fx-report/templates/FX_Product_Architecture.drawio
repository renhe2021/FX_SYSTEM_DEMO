          <mxGeometry x="250" y="100" width="190" height="88" as="geometry"/>
        </mxCell>

        <!-- Step 3 -->
        <mxCell id="s3" value="&lt;b&gt;STEP 3&lt;/b&gt;&lt;br&gt;AI 分析 + 知识库&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;新闻搜索 · 评论生成 · 可编辑&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=40;fillColor=#EDE7F6;strokeColor=#B39DDB;fontColor=#5E35B1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="500" y="100" width="210" height="88" as="geometry"/>
